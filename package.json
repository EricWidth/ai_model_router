{
  "name": "ai-model-router",
  "version": "1.0.0",
  "description": "Unified AI model router with automatic failover",
  "main": "dist/src/index.js",
  "type": "commonjs",
  "bin": {
    "amr": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "cli": "tsx cli/index.ts",
    "pkg": "npm run build && pkg .",
    "smoke:openclaw-ws": "npm run build && node --test dist/src/openclaw-ws-smoke.test.js"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "src/web/public/**/*"
    ],
    "targets": [
      "node18-macos-x64",
      "node18-macos-arm64",
      "node18-windows-x64"
    ],
    "outputPath": "dist/executable"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "winston": "^3.13.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.1",
    "pkg": "^5.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
